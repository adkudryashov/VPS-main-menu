#!/bin/bash

# ======================================================================
# ГЛАВНЫЙ ФАЙЛ МЕНЮ
# ======================================================================

# Подключаем все общие переменные и функции
source /usr/local/bin/_config_and_utils.sh

function check_for_updates {
    # Переходим в физическую папку репозитория, чтобы Git видел .git
    cd /root/VPS-main-menu || return
    
    # Проверяем наличие .git
    [ ! -d .git ] && return

    # Запрашиваем инфо с GitHub
    git fetch origin main &>/dev/null
    
    LOCAL=$(git rev-parse HEAD)
    REMOTE=$(git rev-parse origin/main)

    if [ "$LOCAL" != "$REMOTE" ]; then
        echo -e "${YELLOW}======================================================"
        echo -e "📢  ${GREEN}ДОСТУПНО ОБНОВЛЕНИЕ!${NC}"
        echo -e "${YELLOW}------------------------------------------------------"
        echo -e "${CYAN}Что нового:${NC}"
        git log HEAD..origin/main --pretty=format:"- %s%n  %b"
        echo -e "${YELLOW}------------------------------------------------------"
        echo -e "Нажмите ${GREEN}[8]${NC} в меню для автообновления."
        echo -e "======================================================${NC}"
        echo ""
        # ВАЖНО: Пауза, чтобы уведомление не стерлось командой clear
        read -p "Нажмите [Enter], чтобы продолжить..."
    fi
}

# --- ГЛАВНОЕ МЕНЮ ---
function show_menu {
    clear
    echo -e "${CYAN}======================================================${NC}"
    echo -e "${CYAN}             🚀  МЕНЮ УПРАВЛЕНИЯ СЕРВЕРОМ  🚀        ${NC}"
    echo -e "${CYAN}======================================================${NC}"
    
    # --- БЛОК ОТОБРАЖЕНИЯ ХАРАКТЕРИСТИК ---
    # --- СБОР ДАННЫХ В СТИЛЕ BENCH.SH ---
    # CPU
    if command -v lscpu &> /dev/null; then
        CPU_MODEL=$(lscpu 2>/dev/null | grep 'Model name:' | head -n 1 | awk -F ':' '{print $2}' | sed -e 's/^[ \t]*//')
        CPU_CORES=$(nproc)
        CPU_FREQ=$(lscpu | grep -i "CPU MHz" | awk -F': ' '{print $2}' | xargs)
		if [ -z "$CPU_FREQ" ]; then
    CPU_FREQ=$(grep -m1 "cpu MHz" /proc/cpuinfo | awk -F': ' '{print $2}' | xargs)
fi
        CPU_CACHE=$(lscpu | grep "L3 cache" | awk '{print $3$4}')
    else
        CPU_MODEL="Не определено"; CPU_CORES="?"; CPU_FREQ="?"; CPU_CACHE="?"
    fi

    # AES-NI / Virtualization
    AES_NI=$(grep -qw aes /proc/cpuinfo && echo -e "${GREEN}✓ Включено${NC}" || echo -e "${RED}✗ Выключено${NC}")
    VM_X=$(grep -Eow "vmx|svm" /proc/cpuinfo > /dev/null && echo -e "${GREEN}✓ Включено${NC}" || echo -e "${RED}✗ Выключено${NC}")
    VIRT=$(systemd-detect-virt 2>/dev/null || echo "Unknown")

    # DISK & MEM
    RAM_TOTAL_RAW=$(grep MemTotal /proc/meminfo | awk '{print $2/1024/1024}')
    RAM_TOTAL=$(printf "%.1f" $RAM_TOTAL_RAW)
    MEM_FREE=$(grep MemAvailable /proc/meminfo | awk '{print $2/1024/1024}')
    MEM_USED=$(echo "$RAM_TOTAL - $MEM_FREE" | bc -l)
    
    DISK_USAGE=$(df -h --output=size,used / | tail -n 1)
    read -r D_TOTAL D_USED <<< "$DISK_USAGE"

    # SYSTEM INFO
    UPTIME_RAW=$(uptime -p | sed 's/up //')
    UPTIME=$(echo "$UPTIME_RAW" | sed -e 's/years\?/лет/g' -e 's/weeks\?/недель/g' -e 's/days\?/дн./g' -e 's/hours\?/час./g' -e 's/minutes\?/мин./g')
    LOAD_AVG=$(awk '{print $1", "$2", "$3}' /proc/loadavg)
    OS_NAME=$(grep "PRETTY_NAME" /etc/os-release | cut -d'"' -f2)
    ARCH=$(uname -m)
    KERNEL=$(uname -r)
    TCP_CC=$(sysctl net.ipv4.tcp_congestion_control | awk '{print $3}')

    # NETWORK & GEO 
    IPV4=$(curl -s4 ipinfo.io/ip 2>/dev/null || echo -e "${RED}✗ Offline${NC}")
    IPV6=$(get_public_ipv6)
    GEO_DATA=$(curl -s "http://ip-api.com/json/$IPV4?lang=ru&fields=status,message,country,regionName,city,isp,org,as")
    COUNTRY=$(echo "$GEO_DATA" | jq -r '.country' 2>/dev/null || echo "$GEO_DATA" | grep -oP '"country":"\K[^"]+')
    LOC=$(echo "$GEO_DATA" | jq -r '.city' 2>/dev/null || echo "$GEO_DATA" | grep -oP '"city":"\K[^"]+')
    REG=$(echo "$GEO_DATA" | jq -r '.regionName' 2>/dev/null || echo "$GEO_DATA" | grep -oP '"regionName":"\K[^"]+')
    ORG=$(echo "$GEO_DATA" | jq -r '.org' 2>/dev/null || echo "$GEO_DATA" | grep -oP '"org":"\K[^"]+')
    if [ -z "$ORG" ] || [ "$ORG" == "null" ]; then
        ORG=$(echo "$GEO_DATA" | jq -r '.isp' 2>/dev/null || echo "$GEO_DATA" | grep -oP '"isp":"\K[^"]+')
    fi
    # --- ВЫВОД МЕНЮ В СТИЛЕ BENCH.SH ---
    echo -e "${BLUE}----------------------------------------------------------------------${NC}"
    echo -e " 💻  Модель процессора   : ${YELLOW}$CPU_MODEL${NC}"
    echo -e " 🧠  Ядра процессора     : ${YELLOW}$CPU_CORES @ ${CPU_FREQ} MHz${NC}"
    echo -e " 🗄️   Кэш процессора      : ${YELLOW}$CPU_CACHE${NC}"
    echo -e " 🔐  AES-NI              : $AES_NI"
    echo -e " 📦  VM-x/AMD-V          : $VM_X"
    echo -e " 💾  Всего диска         : ${YELLOW}$D_TOTAL ($D_USED использовано)${NC}"
    echo -e " 🐏  Всего памяти        : ${YELLOW}$RAM_TOTAL GB ($(printf "%.1f" $MEM_USED) GB использовано)${NC}"
    echo -e " ⏱️   Время работы        : ${YELLOW}$UPTIME${NC}"
    echo -e " 📈  Средняя нагрузка    : ${YELLOW}$LOAD_AVG${NC}"
    echo -e " 🐧  ОС                  : ${YELLOW}$OS_NAME${NC}"
    echo -e " 🏗️   Архитектура         : ${YELLOW}$ARCH (64 Bit)${NC}"
    echo -e " ⚙️   Ядро                : ${YELLOW}$KERNEL${NC}"
    echo -e " 🚀  TCP CC              : ${YELLOW}$TCP_CC${NC}"
    echo -e " ☁️   Виртуализация       : ${YELLOW}$VIRT${NC}"
    echo -e " 🌐  IPv4 / IPv6         : ${GREEN}$IPV4${NC} / ${GREEN}${IPV6}${NC}"
    echo -e " 🌍  Страна              : ${YELLOW}$COUNTRY${NC}"
    echo -e " 🏢  Организация         : ${YELLOW}$ORG${NC}"
    echo -e " 📍  Локация             : ${YELLOW}$LOC${NC}"
    echo -e " 🗺️   Регион              : ${YELLOW}$REG${NC}"
    echo -e "${BLUE}----------------------------------------------------------------------${NC}"
    
    # СТАТУС ПРИЛОЖЕНИЙ
    echo -e "${BLUE}--- СТАТУС ПРИЛОЖЕНИЙ --------------------------------${NC}"
    # Проверка X-UI
    if systemctl is-active --quiet x-ui; then status_xui="${GREEN}РАБОТАЕТ${NC}"; else status_xui="${RED}Остановлен${NC}"; fi
    
    # Исправленная проверка Hysteria2 (ищет любой юнит, содержащий hysteria)
    if systemctl list-units --type=service --state=running | grep -qi "hysteria"; then 
        status_hy2="${GREEN}РАБОТАЕТ${NC}"
    else 
        status_hy2="${RED}Остановлен${NC}"
    fi
    
    # Проверка MTProxy (по имени контейнера в Docker)
    if command -v docker &> /dev/null && sudo docker ps --format '{{.Names}}' 2>/dev/null | grep -q "mtproto-proxy"; then 
        status_mtp="${GREEN}РАБОТАЕТ${NC}"
    else 
        status_mtp="${RED}Остановлен${NC}"
    fi

    echo -e "    🎛️   X-UI:        [$status_xui]"
    echo -e "    🎭  Hysteria2:   [$status_hy2]"
    echo -e "    ✈️   MTProxy:     [$status_mtp]"
    
    echo -e "${BLUE}--- ДЕЙСТВИЯ ---------------------------------------${NC}"
    echo -e "${YELLOW}1) 🎛️   Управление X-UI (Установка/Запуск/Статус)${NC}"
    echo -e "${YELLOW}2) 🎭  Управление Hysteria2 (Установка/Старт/Стоп/Пользователи)${NC}"
    echo -e "${YELLOW}3) ✈️   Управление MTProxy (Установка/Пользователи)${NC}"
    echo -e "${GREEN}4) 🧪  Тестирование сервера (Скорость/Блокировки/Сканер)${NC}"
    echo -e "${GREEN}5) ⚙️   Настройка и оптимизация сервера${NC}"
    echo -e "${GREEN}6) 🌐  Меню IPv6 (Вкл/Выкл/Статус)${NC}"
    echo -e "${YELLOW}7) 🛠️   Системные утилиты (htop, ncdu, сеть, очистка)${NC}"
    echo -e "${CYAN}8) 🔄  ОБНОВИТЬ СКРИПТЫ (с GitHub)${NC}"
    echo -e "${RED}X) 🚪  Выход в оболочку${NC}"
    echo -e "${BLUE}------------------------------------------------------${NC}"
}

# ГЛАВНЫЙ ЦИКЛ ЗАПУСКА - вызывает внешние скрипты
while true; do
    check_for_updates
    show_menu
    PROMPT=$(echo -e "${CYAN}Ваш выбор: ${NC}")
    read -p "$PROMPT" choice

    case $choice in
        1) /usr/local/bin/menu_xui.sh ;;
        2) /usr/local/bin/menu_hysteria.sh ;;
		3) /usr/local/bin/menu_mtproxy.sh ;;
        4) /usr/local/bin/menu_tests.sh ;;
        5) /usr/local/bin/menu_setup.sh ;;
        6) /usr/local/bin/ipv6-menu ;;
        7) /usr/local/bin/menu_utils.sh ;;
        8)
           echo -e "${YELLOW}>>> Принудительное обновление через Git...${NC}"
           cd /root/VPS-main-menu || exit
           git fetch origin main &>/dev/null
           if git reset --hard origin/main > /dev/null; then 
               chmod +x /root/VPS-main-menu/*
			   for file in /root/VPS-main-menu/*.sh /root/VPS-main-menu/server-menu /root/VPS-main-menu/ipv6-menu; do [ -f "$file" ] && ln -sf "$file" "/usr/local/bin/$(basename "$file")"; done
               echo -e "${GREEN}✅ Обновлено! Перезапуск...${NC}"
               sleep 1
               exec bash "$0"
           else
               echo -e "${RED}❌ Ошибка обновления.${NC}"
               read -p "Нажмите Enter..."
           fi
           ;;
        [Xx])                                   
            echo -e "${GREEN}Выход в оболочку.${NC}"
            break
            ;;
        *)
            echo -e "${RED}❌ Неверный ввод.${NC}"
            sleep 1
            ;;
    esac
done
